// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid @map("id")
  userId      String   @unique @db.Uuid @map("user_id")
  email       String   @unique @map("email")
  fullName    String?  @map("full_name")
  role        Role     @default(CUSTOMER) @map("role")

  eduVerified Boolean  @default(false) @map("edu_verified")

  orgName     String?  @map("org_name")
  orgEmail    String?  @unique @map("org_email")

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("profiles")
}

enum Role {
  ADMIN
  CUSTOMER
}
